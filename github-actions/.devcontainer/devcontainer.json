{
  "name": "kubasejdak python:3.14-26.04",
  "image": "kubasejdak/python:3.14-26.04",
  "workspaceFolder": "/github-actions",
  "workspaceMount": "source=${localWorkspaceFolder},target=/github-actions/workspace,type=bind,consistency=cached",
  "mounts": [
    "source=${localEnv:HOME}/.gitconfig,target=/home/ubuntu/.gitconfig,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.ssh,target=/home/ubuntu/.ssh,type=bind,consistency=cached",
    "source=${localEnv:HOME}/projects/kubasejdak/tools/binary-run-action,target=/github-actions/binary-run-action,type=bind,consistency=cached",
    "source=${localEnv:HOME}/projects/kubasejdak/tools/clang-format-run-action,target=/github-actions/clang-format-run-action,type=bind,consistency=cached",
    "source=${localEnv:HOME}/projects/kubasejdak/tools/clang-tidy-run-action,target=/github-actions/clang-tidy-run-action,type=bind,consistency=cached",
    "source=${localEnv:HOME}/projects/kubasejdak/tools/cmake-build-preset-action,target=/github-actions/cmake-build-preset-action,type=bind,consistency=cached",
    "source=${localEnv:HOME}/projects/kubasejdak/tools/cpp-coverage-check-action,target=/github-actions/cpp-coverage-check-action,type=bind,consistency=cached",
    "source=${localEnv:HOME}/projects/kubasejdak/tools/docker-action,target=/github-actions/docker-action,type=bind,consistency=cached",
    "source=${localEnv:HOME}/projects/kubasejdak/tools/mkdocs-publish-action,target=/github-actions/mkdocs-publish-action,type=bind,consistency=cached",
    "source=${localEnv:HOME}/projects/kubasejdak/tools/openocd-run-action,target=/github-actions/openocd-run-action,type=bind,consistency=cached",
    "source=${localEnv:HOME}/projects/kubasejdak/tools/valgrind-run-action,target=/github-actions/valgrind-run-action,type=bind,consistency=cached"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "charliermarsh.ruff",
        "davidanson.vscode-markdownlint",
        "esbenp.prettier-vscode",
        "hediet.vscode-drawio",
        "mads-hartmann.bash-ide-vscode",
        "ms-python.python",
        "ms-vsliveshare.vsliveshare",
        "waderyan.gitblame",
        "yzhang.markdown-all-in-one"
      ]
    }
  },
  "runArgs": ["--network=host"]
}
