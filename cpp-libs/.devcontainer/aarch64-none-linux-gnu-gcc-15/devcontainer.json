{
  "name": "kubasejdak aarch64-none-linux-gnu-gcc:15-26.04",
  "image": "kubasejdak/aarch64-none-linux-gnu-gcc:15-26.04",
  "workspaceFolder": "/cpp-libs",
  "workspaceMount": "source=${localWorkspaceFolder},target=/cpp-libs/workspace,type=bind,consistency=cached",
  "mounts": [
    "source=${localEnv:HOME}/.gitconfig,target=/home/ubuntu/.gitconfig,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.gitconfig-private,target=/home/ubuntu/.gitconfig-private,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.ssh,target=/home/ubuntu/.ssh,type=bind,consistency=cached",
    "source=${localEnv:HOME}/projects/kubasejdak/libs/cpp/osal,target=/cpp-libs/osal,type=bind,consistency=cached",
    "source=${localEnv:HOME}/projects/kubasejdak/libs/cpp/platform,target=/cpp-libs/platform,type=bind,consistency=cached",
    "source=${localEnv:HOME}/projects/kubasejdak/libs/cpp/utils,target=/cpp-libs/utils,type=bind,consistency=cached"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "davidanson.vscode-markdownlint",
        "esbenp.prettier-vscode",
        "hediet.vscode-drawio",
        "mads-hartmann.bash-ide-vscode",
        "matepek.vscode-catch2-test-adapter",
        "ms-python.python",
        "ms-vscode.cpptools-extension-pack",
        "ms-vsliveshare.vsliveshare",
        "waderyan.gitblame",
        "xaver.clang-format",
        "yzhang.markdown-all-in-one"
      ]
    }
  },
  "runArgs": ["--network=host"]
}
